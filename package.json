{
  "name": "curmanlight-react",
  "private": true,
  "version": "1.5.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "cp index.html.template index.html && vite build && cp dist/index.html index.html",
    "test": "vitest run",
    "memory:start": "powershell -ExecutionPolicy Bypass -File scripts/agent-memory.ps1 start",
    "memory:checkpoint": "powershell -ExecutionPolicy Bypass -File scripts/agent-memory.ps1 checkpoint",
    "memory:status": "powershell -ExecutionPolicy Bypass -File scripts/agent-memory.ps1 status",
    "memory:handoff": "powershell -ExecutionPolicy Bypass -File scripts/agent-memory.ps1 handoff",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@playwright/test": "^1.61.1",
    "dexie": "^4.0.8",
    "dexie-react-hooks": "^1.1.1",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.395.0",
    "playwright": "^1.61.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.1",
    "surge": "^0.31.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.5.3",
    "@storybook/addon-docs": "^10.5.3",
    "@storybook/addon-mcp": "^0.7.0",
    "@storybook/addon-vitest": "^10.5.3",
    "@storybook/react-vite": "^10.5.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "storybook": "^10.5.3",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.2.2",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.0.1",
    "vitest": "^4.1.10"
  }
}
